    {
      "parameters": {
        "resource": "chat",
        "chatModel": "gpt-4o",
        "messagesUi": {
          "messagesValues": [
            {
              "role": "system",
              "message": "Analyze this cold outreach reply. Categorize it into exactly one of these labels: 'interested', 'not now', 'unsubscribe', 'out of office', or 'wrong person'. Do not return anything but the label name."
            },
            {
              "role": "user",
              "message": "=Subject: {{ $json.subject }}\nBody: {{ $json.text }}"
            }
          ]
        }
      },
      "id": "openai-classifier",
      "name": "OpenAI Intent Classifier",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [
        350,
        300
      ]
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.choices[0].message.content.trim().toLowerCase() }}",
        "rules": {
          "rules": [
            {
              "value2": "interested"
            },
            {
              "value2": "unsubscribe"
            },
            {
              "value2": "wrong person"
            }
          ]
        }
      },
      "id": "route-intent",
      "name": "Intent Branching",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        600,
        300
