              "name": "profile_url",
              "value": "={{ $node[\"Split in Batches\"].json.linkedin_url }}"
            },
            {
              "name": "message",
              "value": "=Hey {{ $node[\"Split in Batches\"].json.first_name }}, would love to connect."
            }
          ]
        }
      },
      "id": "unipile-linkedin",
      "name": "Unipile LinkedIn Connect",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        2100,
        -100
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.instantly.ai/v1/lead/add",
        "sendHeaders": true,
        "headersUi": {
          "parameter": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ process.env.INSTANTLY_API_KEY || 'YOUR_API_KEY_HERE' }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParametersUi": {
          "parameter": [
            {
              "name": "campaign_id",
              "value": "YOUR_CAMPAIGN_ID"
            },
            {
              "name": "email",
              "value": "={{ $node[\"Split in Batches\"].json.email }}"
            },
            {
              "name": "first_name",
              "value": "={{ $node[\"Split in Batches\"].json.first_name }}"
            },
            {
              "name": "last_name",
              "value": "={{ $node[\"Split in Batches\"].json.last_name }}"
            },
            {
              "name": "variables",
              "value": "={ \"first_line\": \"{{ $node[\"OpenAI Personalize\"].json.choices[0].message.content }}\" }"
            }
          ]
        }
      },
      "id": "instantly-sync",
      "name": "Instantly Sequence Sync",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        2350,
        -100
      ]
    },
    {
      "parameters": {
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        },
        "simple": false,
        "filters": {}
