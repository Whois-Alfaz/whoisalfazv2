        "url": "YOUR_SLACK_WEBHOOK_URL",
        "sendBody": true,
        "bodyParametersUi": {
          "parameter": [
            {
              "name": "text",
              "value": "=🔥 Hot Lead Alert! A prospect has replied with positive intent.\nSender: {{ $node[\"Gmail Trigger\"].json.from.value[0].address }}\nSubject: {{ $node[\"Gmail Trigger\"].json.subject }}\nReply: {{ $node[\"Gmail Trigger\"].json.text }}"
            }
          ]
        }
      },
