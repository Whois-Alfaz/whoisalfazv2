            }
          ]
        }
      },
      "id": "brevo-update",
      "name": "Brevo Update Contact",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1850,
        100
      ]
    },
    {
      "parameters": {
        "jsCode": "const contact = $node[\"Is Signature Valid\"].json.data;\nlet score = 0;\n\nconst headcount = contact.organization?.estimated_num_employees || 0;\nif (headcount >= 50 && headcount <= 500) score += 40;\nelse if (headcount > 500) score += 20;\n\nconst highValueIndustries = ['saas', 'software', 'fintech', 'martech'];\nif (highValueIndustries.some(i => contact.organization?.industry?.toLowerCase().includes(i))) {\n  score += 30;\n}\n\nconst decisionMakerTitles = ['founder', 'ceo', 'vp', 'head of', 'director'];\nif (decisionMakerTitles.some(t => contact.title?.toLowerCase().includes(t))) {\n  score += 30;\n}\n\nreturn {\n  json: {\n    ...contact,\n    icp_score: score,\n    sequence_id: score >= 70 \n      ? (process.env.BREVO_SEQUENCE_TIER_1 || 'tier1_sequence')\n      : (process.env.BREVO_SEQUENCE_TIER_2 || 'tier2_sequence')\n  }\n};"
      },
      "id": "icp-scoring",
      "name": "ICP Scoring & Routing",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2100,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-tier1",
              "leftValue": "={{ $json.icp_score }}",
              "comparison": "number_greaterEqual",
              "rightValue": 70
            }
          ],
          "combinator": "and"
        }
      },
