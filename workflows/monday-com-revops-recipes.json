        "unit": "minutes"
      }
    },
    {
      "id": "query-lead-touch-status",
      "name": "Query Lead Touch Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        750,
        200
      ],
      "parameters": {
        "method": "POST",
        "url": "https://api.monday.com/v2",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
