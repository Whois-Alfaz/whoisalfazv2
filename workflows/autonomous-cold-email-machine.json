    {
      "parameters": {
        "jsCode": "const inputItems = $input.all();\nconst mergedPayloads = [];\n\nfor (const item of inputItems) {\n  const incomingData = item.json.data || {\n    email: \"lead@company.com\",\n    phone: \"+123456789\",\n    title: \"CTO\",\n    linkedin_url: \"https://linkedin.com/in/test\",\n    organization: { name: \"Acme Corp\", industry: \"SaaS\" }\n  };\n  \n  const existingCRMData = item.json.email ? item.json : null; \n  \n  if (!existingCRMData) {\n    mergedPayloads.push({\n      json: {\n        action: \"create\",\n        payload: {\n          email: incomingData.email,\n          phone: incomingData.phone,\n          jobTitle: incomingData.title,\n          linkedinUrl: incomingData.linkedin_url,\n          companyName: incomingData.organization?.name,\n          industry: incomingData.organization?.industry\n        }\n      }\n    });\n    continue;\n  }\n  \n  const updatePayload = {};\n  const criticalKeys = ['phone', 'jobTitle', 'linkedinUrl', 'companyName', 'industry'];\n  const mappedIncoming = {\n    phone: incomingData.phone,\n    jobTitle: incomingData.title,\n    linkedinUrl: incomingData.linkedin_url,\n    companyName: incomingData.organization?.name,\n    industry: incomingData.organization?.industry\n  };\n  const mappedCRM = {\n    phone: existingCRMData.attributes?.PHONE,\n    jobTitle: existingCRMData.attributes?.JOBTITLE,\n    linkedinUrl: existingCRMData.attributes?.LINKEDIN,\n    companyName: existingCRMData.attributes?.COMPANY,\n    industry: existingCRMData.attributes?.INDUSTRY\n  };\n  \n  for (const key of criticalKeys) {\n    const incomingValue = mappedIncoming[key];\n    const existingValue = mappedCRM[key];\n    \n    if (incomingValue && (!existingValue || existingValue === \"\" || existingValue === null)) {\n      updatePayload[key] = incomingValue;\n    }\n  }\n  \n  updatePayload.email = existingCRMData.email || incomingData.email;\n  updatePayload.id = existingCRMData.id;\n  \n  const hasUpdates = Object.keys(updatePayload).length > 2;\n  \n  mergedPayloads.push({\n    json: {\n      action: hasUpdates ? \"update\" : \"skip\",\n      payload: updatePayload\n    }\n  });\n}\n\nreturn mergedPayloads;"
      },
